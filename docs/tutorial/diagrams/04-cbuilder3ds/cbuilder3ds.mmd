---
title: What CBuilder3DS Does
---
flowchart TB
  subgraph IN["You provide"]
    direction LR
    IN_C["C source<br/>source/*.c · headers"]
    IN_A["Assets<br/>banner.png · icon.png · audio.wav"]
  end

  PREREQ["devkitPro + devkitARM + libctru<br/>installed separately — not bundled"]

  CB(["CBuilder3DS<br/>──────────────<br/>all-in-one project template<br/>Makefile · build.bat · template.rsf<br/>ships bannertool + makerom"])

  subgraph ROW["Orchestrates — does not compile itself"]
    direction LR
    S1["① make<br/>arm-none-eabi-gcc + libctru"]
    S2["② bannertool<br/>.bnr + .icn"]
    S3["③ makerom<br/>+ template.rsf"]
  end

  subgraph OUT["Outputs"]
    direction LR
    O_ELF[".elf"]
    O_3DSX[".3dsx"]
    O_CIA[".cia"]
    O_3DS[".3ds"]
  end

  NOT["Not a compiler · not libctru<br/>optional if you maintain your own Makefile"]

  IN_C --> CB
  IN_A --> CB
  PREREQ -.-> CB

  CB --> S1
  CB --> S2
  CB --> S3

  S1 --> O_ELF
  S1 --> O_3DSX
  S2 --> S3
  S1 --> S3
  S3 --> O_CIA
  S3 --> O_3DS

  CB -.-> NOT

  IN_C ~~~ IN_A
  S1 ~~~ S2
  S2 ~~~ S3
  CB ~~~ ROW

